{
    dataset_id: "baseline__electricity_per_vehicle_km_projections",
    version: "1.0.0",
    dataset_type: "modeled",
    data_layout: {
        table_format: "one_table",
        value_format: "stacked",
        data_file: {
            path: "load_data.csv",
            columns: [
                {
                    name: "Country",
                    dimension_type: "geography",
                },
                {
                    name: "Year",
                    dimension_type: "model_year",
                },
            ]
        }
    },
    description: "Electricity consumption per vehicle kilometer projections for STRIDE test dataset",
    data_classification: "low",
    dimensions: [
        {
            type: "metric",
            "class": "EnergyEfficiency",
            name: "electricity_per_vehicle_km",
            description: "Electricity consumption per vehicle kilometer",
            module: "dsgrid.dimension.standard",
            records: [
                {
                    id: "Wh_per_vehicle_km",
                    name: "Electricity per Vehicle Kilometer",
                    fuel_id: "electricity",
                    unit: "Wh/km",
                },
            ],
        },
        {
            type: "model_year",
            "class": "ModelYear",
            name: "model_year",
            file: "../../dimensions/model_years.csv",
        },
        {
            type: "geography",
            "class": "Geography",
            name: "country",
            file: "../../dimensions/countries.csv",
        },
        {
            type: "subsector",
            "class": "Subsector",
            name: "ev_powertrain",
            records: [
                {
                    id: "bev",
                    name: "Battery Electric Vehicle",
                },
                {
                    id: "phev",
                    name: "Plug-in Hybrid Electric Vehicle",
                },
            ],
        },
    ],
    dimension_references: [],
    trivial_dimensions: ["metric"],
    sector_description: "transportation",
    data_source: "STRIDE Team",
    data_source_date: "2025",
    data_source_doi_url: "https://github.com/dsgrid/stride-data",
}
