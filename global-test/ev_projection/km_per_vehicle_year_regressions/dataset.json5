{
    dataset_id: "baseline__km_per_vehicle_year_regressions",
    version: "1.0.0",
    dataset_type: "modeled",
    data_layout: {
        table_format: "one_table",
        value_format: "stacked",
        data_file: {
            path: "load_data.csv",
            columns: [
                {
                    name: "country",
                    dimension_type: "geography",
                },
            ]
        }
    },
    description: "Kilometers per vehicle year regression parameters for STRIDE test dataset",
    data_classification: "low",
    dimensions: [
        {
            type: "geography",
            "class": "Geography",
            name: "country",
            file: "../../dimensions/countries.csv",
        },
        {
            type: "metric",
            "class": "EnergyServiceDemandRegression",
            name: "metric",
            description: "Slope, intercept, and starting year (t0) parameters for kilometers per vehicle year exponential regressions. Regressions describe change in the number of kilometers per vehicle year over time.",
            file: "dimensions/km_per_vehicle_year_regression_parameters.csv",
        },
    ],
    dimension_references: [],
    trivial_dimensions: [],
    sector_description: "transportation",
    data_source: "STRIDE Team",
    data_source_date: "2025",
    data_source_doi_url: "https://github.com/dsgrid/stride-data",
}
