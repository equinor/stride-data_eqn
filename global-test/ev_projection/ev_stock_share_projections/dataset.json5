{
    dataset_id: "STRIDE_Test_EV_Stock_Share_Projections",
    version: "1.0.0",
    dataset_type: "modeled",
    data_schema: {
        data_schema_type: "one_table",
        table_format: {
            format_type: "unpivoted",
        },
    },
    description: "Electric vehicle stock share projections for STRIDE test dataset",
    data_classification: "low",
    use_project_geography_time_zone: true,
    dimensions: [
        {
            type: "metric",
            "class": "StockShare",
            name: "ev_stock_share",
            description: "Electric vehicle stock share",
            module: "dsgrid.dimension.standard",
            records: [
                {
                    id: "ev_stock_share",
                    name: "EV Stock Share",
                    unit: "fraction",
                },
            ],
        },
        {
            type: "model_year",
            "class": "ModelYear",
            name: "model_year",
            file: "../../dimensions/model_years.csv",
        },
        {
            type: "geography",
            "class": "Geography",
            name: "country",
            file: "../../dimensions/countries.csv",
        },
    ],
    dimension_references: [],
    trivial_dimensions: [],
    sector_description: "transportation",
    data_source: "STRIDE Team",
    data_source_date: "2025",
    data_source_doi_url: "https://github.com/dsgrid/stride-data",
    dimension_columns: {
        Country: "geography",
        Year: "model_year",
    },
}