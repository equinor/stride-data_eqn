{
    dataset_id: "STRIDE_Test_Vehicles_per_Capita_Regression_Parameters",
    version: "1.0.0",
    dataset_type: "modeled",
    data_layout: {
        table_format: "one_table",
        value_format: "stacked",
        data_file: {
            path: "load_data.csv",
            columns: [
                {
                    name: "region",
                    dimension_type: "geography",
                },
            ]
        }
    },
    description: "Vehicles per capita regression parameters for STRIDE test dataset.",
    data_classification: "low",
    use_project_geography_time_zone: true,
    dimensions: [
        {
            type: "geography",
            "class": "Geography",
            name: "region",
            file: "dimensions/regions.csv",
        },
        {
            type: "metric",
            "class": "StockRegression",
            name: "metric",
            description: "Slope, intercept, and starting year (t0) parameters for cars per capita linear regressions. Regressions describe change in the number of cars per person year over year.",
            file: "dimensions/vehicles_per_capita_regression_parameters.csv",
        },
    ],
    dimension_references: [],
    trivial_dimensions: [],
    sector_description: "transportation",
    data_source: "STRIDE Team",
    data_source_date: "2025",
    data_source_doi_url: "https://github.com/dsgrid/stride-data",
}