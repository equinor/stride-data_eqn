{
    project_id: "test_project",
    creator: "tester",
    description: "This is a test project.",
    datasets: [],
    dimensions: {
        base_dimensions: [
            {
                type: "scenario",
                class: "Scenario",
                module: 'dsgrid.dimension.standard',
                name: "default",
                description: "Default scenario",
                records: [{id: "default", name: "default"}],
            },
            {
                type: 'model_year',
                class: 'ModelYear',
                name: 'model_year',
                description: 'Selected model years',
                file: 'dimensions/model_years.csv',
                module: 'dsgrid.dimension.standard',
            },
            {
                type: 'weather_year',
                class: 'WeatherYear',
                name: 'weather_year',
                description: "Selected weather year",
                records: [
                    {id: '2018', name: '2018'}
                ],
                module: 'dsgrid.dimension.standard'
            },
            // Time could be period beginning, hourly, aligned with weather_year
            // and in the dominant time zone for the selected country. Right now
            // the chronify time zones are US-centric: https://github.com/NREL/chronify/blob/main/src/chronify/time.py#L138.
            {
                type: 'geography',
                class: 'Geography',
                name: 'country',
                description: 'All countries available for analysis in this test project',
                file: 'dimensions/countries.csv',
                module: 'dsgrid.dimension.standard',
            },
            {
                type: 'sector',
                class: 'Sector',
                name: 'sector',
                description: 'Industrial, residential, and transportation sectors',
                file: 'dimensions/sectors.csv',
                module: 'dsgrid.dimension.standard',
            },
            {
                type: "subsector",
                class: "Subsector",
                module: 'dsgrid.dimension.standard',
                name: "subsector",
                description: "Subsectors in the STRIDE global dataset",
                file: "dimensions/subsectors.csv",
            },
            {
                type: 'metric',
                class: 'EnergyEndUse',
                name: 'end use',
                description: 'Temporary placeholder for annual energy',
                records: [
                    {id: 'unspecified', name: 'Unspecified', fuel_id: 'electricity', unit: 'MWh'}
                ],
                module: 'dsgrid.dimension.standard'
            },
            {
                type: 'metric',
                class: 'Population',
                name: 'population',
                description: 'Number of people',
                records: [
                    {id: 'population', name: 'Population', unit: 'people'}
                ],
                module: 'dsgrid.dimension.standard'
            },
            {
                type: 'metric',
                class: 'FractionalIndex',
                name: 'HDI',
                description: 'Human Development Index',
                records: [
                    {id: 'hdi',name: 'HDI',unit: 'HDI', min_value: 0.0, max_value: 1.0}
                ],
                module: 'dsgrid.dimension.standard'
            },
            {
                type: 'metric',
                class: 'Stock',
                name: 'GDP',
                description: 'Gross Domestic Product',
                records: [
                    {id: 'gdp', name: 'GDP', unit: 'billion USD-2024'}
                ],
                module: 'dsgrid.dimension.standard'
            },
            {
                type: "metric",
                "class": "EnergyIntensityRegression",
                name: "metric",
                description: "Slope, intercept, and starting year (t0) parameters for energy intensity regressions. Supports linear and log-linear (exponential) regressions of energy intensity either per HDI-person or per GDP. Regressions describe change in energy intensity year over year.",
                file: "../default_projection/energy_intensity_regressions/dimensions/energy_intensity_regression_parameters.csv",
            },
            {
                type: 'metric',
                class: 'EnergyIntensity',
                name: 'energy intensity',
                description: 'Energy intensity by HDI-population or GDP',
                records: [
                    {id: 'res_energy_intensity', name: 'Residential Energy Intensity', unit: 'MWh/HDI-person'},
                    {id: 'nonres_energy_intensity', name: 'Non-residential Energy Intensity', unit: 'MWh/billion USD-2024'},
                ],
                module: 'dsgrid.dimension.standard'
            }
        ]
    }
}
