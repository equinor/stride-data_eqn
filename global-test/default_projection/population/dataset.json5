{
    dataset_id: "baseline__population",
    version: "1.0.0",
    dataset_type: "modeled",
    data_layout: {
        table_format: "one_table",
        value_format: "stacked",
        data_file: {
            path: "load_data.csv",
            columns: [
                {
                    name: "country",
                    dimension_type: "geography",
                },
                {
                    name: "year",
                    dimension_type: "model_year",
                },
            ]
        }
    },
    description: "Fictitious population data for STRIDE test dataset",
    data_classification: "low",
    dimensions: [
        {
            type: "metric",
            "class": "Population",
            name: "population",
            description: "Number of people",
            module: "dsgrid.dimension.standard",
            records: [
                {
                    id: "population",
                    name: "population",
                    unit: "people",
                },
            ],
        },
        {
            type: "model_year",
            "class": "ModelYear",
            name: "model_year",
            file: "../../dimensions/model_years.csv",
        },
        {
            type: "geography",
            "class": "Geography",
            name: "country",
            file: "../../dimensions/countries.csv",
        },
    ],
    dimension_references: [],
    trivial_dimensions: [
        "metric",
    ],
    sector_description: "macroeconomics",
    data_source: "STRIDE Team",
    data_source_date: "2025",
    data_source_doi_url: "https://github.com/dsgrid/stride-data",
}
