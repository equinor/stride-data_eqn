{
    dataset_id: "UN_population_median_2024",
    version: "1.0.0",
    dataset_type: "modeled",
    data_schema: {
        data_schema_type: "one_table",
        table_format: {
            format_type: "unpivoted",
        },
    },
    description: "Historical and median projected population data",
    data_classification: "low",
    use_project_geography_time_zone: true,
    dimensions: [
        {
            type: "metric",
            "class": "Population",
            name: "population",
            description: "Number of people",
            module: "dsgrid.dimension.standard",
            records: [
                {
                    id: "population",
                    name: "population",
                    unit: "people",
                },
            ],
        },
        {
            type: "model_year",
            "class": "ModelYear",
            name: "model_year",
            file: "../../dimensions/model_years.csv",
        },
        {
            type: "geography",
            "class": "Geography",
            name: "country",
            file: "../../dimensions/countries.csv",
        },
    ],
    dimension_references: [],
    trivial_dimensions: [
        "metric",
    ],
    sector_description: "macroeconomics",
    data_source: "United Nations World Population Prospects",
    data_source_date: "2024",
    data_soruce_doi_url: "https://population.un.org/wpp/",
    dimension_columns: {
        country: "geography",
        year: "model_year",
    },
}