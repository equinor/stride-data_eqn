{
    dataset_id: "WEO_CEBR_2024",
    version: "1.0.0",
    dataset_type: "modeled",
    data_schema: {
        data_schema_type: "one_table",
        table_format: {
            format_type: "unpivoted",
        },
    },
    description: "Historical GDP from the 2024 IMF World Economic Outlook (WEO) and GDP forecasts from the Centre for Economics and Business Research (CEBR) 2024 World Economic League Table",
    data_classification: "low",
    use_project_geography_time_zone: true,
    dimensions: [
        {
            type: "metric",
            "class": "Stock",
            name: "gdp",
            description: "Gross Domestic Product",
            module: "dsgrid.dimension.standard",
            records: [
                {
                    id: "gdp",
                    name: "GDP",
                    unit: "billion USD-2024",
                },
            ],
        },
        {
            type: "model_year",
            "class": "ModelYear",
            name: "model_year",
            file: "../../dimensions/model_years.csv",
        },
        {
            type: "geography",
            "class": "Geography",
            name: "country",
            file: "../../dimensions/countries.csv",
        },
    ],
    dimension_references: [],
    trivial_dimensions: [
        "metric",
    ],
    sector_description: "macroeconomics",
    data_source: "International Monetary Fund (IMF) and Centre for Economics and Business Research (CEBR)",
    data_source_date: "2024",
    data_source_doi_url: "https://www.imf.org/en/Publications/WEO/weo-database/2024/October/weo-report;https://cebr.com/world-economic-league-table/",
    dimension_columns: {
        country: "geography",
        year: "model_year",
    },
}