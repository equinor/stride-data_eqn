{
    dataset_id: "baseline__hdi",
    version: "1.0.0",
    dataset_type: "modeled",
    data_layout: {
        table_format: "one_table",
        value_format: "stacked",
        pivoted_dimension_type: null,
        data_file: {
            path: "load_data.parquet",
            columns: [
                {
                    name: "country",
                    dimension_type: "geography",
                },
                {
                    name: "year",
                    dimension_type: "model_year",
                },
            ],
        },
    },
    description: "Historical and forecast human development index (HDI)",
    data_classification: "low",
    dimensions: [
        {
            type: "metric",
            "class": "FractionalIndex",
            name: "hdi",
            description: "Human Development Index",
            module: "dsgrid.dimension.standard",
            records: [
                {
                    id: "hdi",
                    name: "HDI",
                    unit: "HDI",
                    min_value: 0.0,
                    max_value: 1.0,
                },
            ],
        },
        {
            type: "model_year",
            "class": "ModelYear",
            name: "model_year",
            file: "../../dimensions/model_years.csv",
        },
        {
            type: "geography",
            "class": "Geography",
            name: "country",
            file: "../../dimensions/countries.csv",
        },
    ],
    dimension_references: [],
    trivial_dimensions: [
        "metric",
    ],
    sector_description: "macroeconomics",
    data_source: "United Nations Development Reports for historical data. Forcasts based on logistic regressions of the historical data.",
    data_source_doi_url: "https://hdr.undp.org/data-center/human-development-index#/indicies/HDI",
}
