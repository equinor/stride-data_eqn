{
    dataset_id: "STRIDE_PHEV_Share_Projections_2025",
    version: "1.0.0",
    dataset_type: "modeled",
    data_layout: {
        table_format: "one_table",
        value_format: "stacked",
        pivoted_dimension_type: null,
        data_file: {
            path: "load_data.parquet",
            columns: [
                {
                    name: "Country",
                    dimension_type: "geography",
                },
                {
                    name: "Year",
                    dimension_type: "model_year",
                },
            ],
        },
    },
    description: "PHEV share of electric vehicle stock projected to hold constant from the last historical value reported by IEA GEO.",
    data_classification: "low",
    use_project_geography_time_zone: true,
    dimensions: [
        {
            type: "metric",
            "class": "StockShare",
            name: "phev_stock_share",
            description: "Plug-in hybrid electric vehicle share of the electric vehicle stock",
            module: "dsgrid.dimension.standard",
            records: [
                {
                    id: "phev_stock_share",
                    name: "PHEV Stock Share",
                    unit: "fraction",
                },
            ],
        },
        {
            type: "model_year",
            "class": "ModelYear",
            name: "model_year",
            file: "../../dimensions/model_years.csv",
        },
        {
            type: "geography",
            "class": "Geography",
            name: "country",
            file: "../ev_stock_share_projections/IEA_GEO_countries_regions.csv",
        },
    ],
    dimension_references: [],
    trivial_dimensions: [
        "metric",
    ],
    sector_description: "transportation",
    data_source: "IEA Global EV Outlook",
    data_source_date: "2025",
    data_source_doi_url: "https://www.iea.org/reports/global-ev-outlook-2025",
}