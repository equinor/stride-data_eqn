{
    dataset_id: "baseline__vehicle_per_capita_regressions",
    version: "1.0.0",
    dataset_type: "modeled",
    data_layout: {
        table_format: "one_table",
        value_format: "stacked",
        pivoted_dimension_type: null,
        data_file: {
            path: "load_data.parquet",
            columns: [
                {
                    name: "country",
                    dimension_type: "geography",
                },
            ],
        },
    },
    description: "Vehicles per capita regression parameters for STRIDE. Cars only in STRIDE 2025.",
    data_classification: "low",
    dimensions: [
        {
            type: "geography",
            "class": "Geography",
            name: "country",
            file: "dimensions/GEO_UN_countries_regions.csv",
        },
        {
            type: "metric",
            "class": "StockRegression",
            name: "metric",
            description: "Slope, intercept, and starting year (t0) parameters for cars per capita linear regressions. Regressions describe change in the number of cars per person year over year.",
            file: "dimensions/vehicles_per_capita_regression_parameters.csv",
        },
    ],
    dimension_references: [],
    trivial_dimensions: [],
    sector_description: "transportation",
    data_source: "IEA Global EV Outlook data on EV stock and EV stock shares for cars combined to estimate vehicles per country per year. Combined with UN population data and regressed to describe changes in cars per capita over time.",
    data_source_date: "2025",
    data_source_doi_url: "https://www.iea.org/reports/global-ev-outlook-2025",
}
