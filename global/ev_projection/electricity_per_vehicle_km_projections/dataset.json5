{
    dataset_id: "baseline__electricity_per_vehicle_km_projections",
    version: "1.0.0",
    dataset_type: "modeled",
    data_layout: {
        table_format: "one_table",
        value_format: "stacked",
        pivoted_dimension_type: null,
        data_file: {
            path: "load_data.parquet",
            columns: [
                {
                    name: "Country",
                    dimension_type: "geography",
                },
                {
                    name: "Year",
                    dimension_type: "model_year",
                },
            ],
        },
    },
    description: "Electricity consumption per vehicle kilometer projected to follow Mid scenario projections from the NREL 2024 TransporatationAnnual Technology Baseline (ATB).",
    data_classification: "low",
    dimensions: [
        {
            type: "metric",
            "class": "EnergyEfficiency",
            name: "electricity_per_vehicle_km",
            description: "Electricity consumption per vehicle kilometer",
            module: "dsgrid.dimension.standard",
            records: [
                {
                    id: "Wh_per_vehicle_km",
                    name: "Electricity per Vehicle Kilometer",
                    fuel_id: "electricity",
                    unit: "Wh/km",
                },
            ],
        },
        {
            type: "model_year",
            "class": "ModelYear",
            name: "model_year",
            file: "../../dimensions/model_years.csv",
        },
        {
            type: "geography",
            "class": "Geography",
            name: "country",
            file: "../ev_stock_share_projections/dimensions/IEA_GEO_countries_regions.csv",
        },
        {
            type: "subsector",
            "class": "Subsector",
            name: "ev_powertrain",
            records: [
                {
                    id: "bev",
                    name: "Battery Electric Vehicle",
                },
                {
                    id: "phev",
                    name: "Plug-in Hybrid Electric Vehicle",
                },
            ],
        },
    ],
    dimension_references: [],
    trivial_dimensions: [
        "metric",
    ],
    sector_description: "transportation",
    data_source: "NREL 2024 Transportation Annual Technology Baseline (ATB), Mid scenario projections for Midsize Battery Electric Vehicles (300-mile range) and Gasoline Extended Range Plug-in Hybrid Electric Vehicle (35-mile electric range). The values for PHEVs account for both Wh/mile and PHEV utility factor (fraction of miles traveled on electricity).",
    data_source_date: "2024",
    data_source_doi_url: "https://atb.nrel.gov/transportation/2024/index",
}
