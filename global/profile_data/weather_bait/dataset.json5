{
    dataset_id: "Temperature_BAIT_Demand_Ninja",
    version: "1.0.0",
    dataset_type: "modeled",
    data_layout: {
        table_format: "one_table",
        value_format: "stacked",
        pivoted_dimension_type: null,
        data_file: {
            path: "load_data.parquet",
        },
    },
    description: "Population-weighted building adjusted internal temperature in degrees centigrade, i.e., building-adjusted internal temperature (BAIT). Daily, country-level averages provided for weather years 1980-2022.",
    data_classification: "low",
    use_project_geography_time_zone: true,
    dimensions: [
        {
            type: "geography",
            "class": "Geography",
            name: "ISO2_country_code",
            file: "dimensions/ISO2_country_codes.csv",
        },
        {
            type: "metric",
            "class": "WeatherVariable",
            name: "bait",
            description: "Building-adjusted internal temperature",
            module: "dsgrid.dimension.standard",
            records: [
                {
                    id: "BAIT",
                    name: "building-adjusted internal temperature",
                    unit: "degree Celsius",
                },
            ],
        },
        {
            type: "weather_year",
            "class": "WeatherYear",
            name: "weather_year",
            file: "dimensions/weather_years.csv",
        },
        {
            type: "time",
            time_type: "datetime",
            time_interval_type: "period_beginning",
            name: "daily",
            description: "Daily time resolution",
            module: "dsgrid.dimension.standard",
            "class": "Time",
            measurement_type: "total",
            ranges: [
                {
                    start: "1980-01-01",
                    end: "2022-12-31",
                    str_format: "%Y-%m-%d",
                },
            ],
            column_format: {
                dtype: "time_format_in_parts",
                year_column: "weather_year",
                month_column: "month",
                day_column: "day",
            },
            time_zone_format: {
                format_type: "aligned_in_clock_time",
