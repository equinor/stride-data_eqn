{
    dataset_id: "baseline__weather_bait",
    version: "1.0.0",
    dataset_type: "modeled",
    data_layout: {
        table_format: "one_table",
        value_format: "pivoted",
        pivoted_dimension_type: "metric",
        data_file: {
            path: "load_data.parquet",
            columns: [
                {
                    name: "country",
                    dimension_type: "geography",
                },
            ],
        },
    },
    description: "Building adjusted internal temperature (BAIT) in degrees centigrade and other weather variables. Daily, country-level averages provided for weather years 1995-2024. Each country is represented by a single, highly or most-populous location.",
    data_classification: "low",
    dimensions: [
        {
            type: "geography",
            "class": "Geography",
            module: "dsgrid.dimension.standard",
            name: "country",
            description: "All countries available for analysis in STRIDE",
            file: "../../dimensions/countries.csv",
        },
        {
            type: "metric",
            "class": "WeatherVariable",
            name: "weather",
            description: "Daily average weather variables calculated using historical ERA5 reanalysis data",
            module: "dsgrid.dimension.standard",
            records: [
                {
                    id: "Temperature",
                    name: "dry-bulb temperature",
                    unit: "degree Celsius",
                },
                {
                    id: "Solar_Radiation",
                    name: "surface solar radiation",
                    unit: "W/m2",
                },
                {
                    id: "Wind_Speed",
                    name: "wind speed at 2m",
                    unit: "m/s",
                },
                {
                    id: "Dew_Point",
                    name: "dew point temperature",
                    unit: "degree Celsius",
                },
                {
                    id: "Humidity",
                    name: "humidity",
                    unit: "g/kg",
                },
                {
                    id: "BAIT",
                    name: "building-adjusted internal temperature",
                    unit: "degree Celsius",
                },
            ],
        },
        {
            type: "weather_year",
            "class": "WeatherYear",
            name: "weather_year",
            file: "dimensions/weather_years.csv",
        },
        {
            type: "time",
            time_type: "datetime",
            time_interval_type: "period_beginning",
            name: "daily",
            description: "Daily time resolution",
            module: "dsgrid.dimension.standard",
            "class": "Time",
            time_zone_format: {
                format_type: "aligned_in_clock_time",
                time_zones: [
                    "Africa/Abidjan",
                    "Africa/Algiers",
                    "Africa/Cairo",
                    "Africa/Casablanca",
                    "Africa/Johannesburg",
                    "Africa/Khartoum",
