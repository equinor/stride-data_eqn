{
    dataset_id: "baseline__weather_bait",
    version: "1.0.0",
    dataset_type: "modeled",
    data_layout: {
        table_format: "one_table",
        value_format: "pivoted",
        pivoted_dimension_type: "metric",
        data_file: {
            path: "load_data.parquet",
            columns: [
                {
                    name: "country",
                    dimension_type: "geography",
                },
            ],
        },
    },
    description: "Building adjusted internal temperature (BAIT) in degrees centigrade and other weather variables. Daily, country-level averages provided for weather years 1995-2024. Each country is represented by a single, highly or most-populous location.",
    data_classification: "low",
    dimensions: [
        {
            type: "geography",
            "class": "Geography",
            module: "dsgrid.dimension.standard",
            name: "country",
            description: "All countries available for analysis in STRIDE",
            file: "dimensions/countries.csv",
        },
        {
            type: "metric",
            "class": "WeatherVariable",
            name: "weather",
            description: "Daily average weather variables calculated using historical ERA5 reanalysis data",
            module: "dsgrid.dimension.standard",
            records: [
                {
                    id: "Temperature",
                    name: "dry-bulb temperature",
                    unit: "degree Celsius",
                },
                {
                    id: "Solar_Radiation",
                    name: "surface solar radiation",
                    unit: "W/m2",
                },
                {
                    id: "Wind_Speed",
                    name: "wind speed at 2m",
                    unit: "m/s",
                },
                {
                    id: "Dew_Point",
                    name: "dew point temperature",
                    unit: "degree Celsius",
                },
                {
                    id: "Humidity",
                    name: "humidity",
                    unit: "g/kg",
                },
                {
                    id: "BAIT",
                    name: "building-adjusted internal temperature",
                    unit: "degree Celsius",
                },
            ],
        },
        {
            type: "weather_year",
            "class": "WeatherYear",
            name: "weather_year",
            file: "dimensions/weather_years.csv",
        },
        {
            type: "time",
            time_type: "datetime",
            time_interval_type: "period_beginning",
            name: "daily",
            description: "Daily time resolution",
            module: "dsgrid.dimension.standard",
            "class": "Time",
            time_zone_format: {
                format_type: "aligned_in_std_clock_time",
                time_zones: [
                    "Asia/Colombo",
                    "Asia/Kathmandu",
                    "Asia/Kolkata",
                    "Asia/Tehran",
                    "Asia/Yangon",
                    "Etc/GMT+6",
                    "Etc/GMT+5",
                    "Etc/GMT+4",
                    "Etc/GMT+3",
                    "Etc/GMT",
                    "Etc/GMT-1",
                    "Etc/GMT-2",
                    "Etc/GMT-3",
                    "Etc/GMT-4",
                    "Etc/GMT-5",
                    "Etc/GMT-6",
                    "Etc/GMT-7",
                    "Etc/GMT-8",
                    "Etc/GMT-9",
                    "Etc/GMT-10",
                    "Etc/GMT-13",
                ],
            },
            measurement_type: "total",
            ranges: [
                {
                    start: "1995-01-01",
                    end: "2024-12-31",
                    str_format: "%Y-%m-%d",
                    frequency: "P1DT0H0M0.000000S",
                },
            ],
            column_format: {
                dtype: "time_format_in_parts",
                year_column: "weather_year",
                month_column: "month",
                day_column: "day",
            },
        },
    ],
    dimension_references: [],
    trivial_dimensions: [],
    sector_description: "weather",
    data_source: "ERA5 reanalysis weather data combined with calculations similar to those described in: Staffell, Pfenninger, and Johnson. 2023. A global model of hourly space heating and cooling demand at multiple spatial scales. Nature Energy. 8, 1328-1344.",
    data_source_date: "2025",
    data_source_doi_url: "https://cds.climate.copernicus.eu/datasets/reanalysis-era5-single-levels?tab=overview;https://doi.org/10.1038/s41560-023-01341-5",
}