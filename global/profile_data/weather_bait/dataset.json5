                    "Europe/Warsaw",
                    "Europe/Zurich",
                    "Indian/Mauritius",
                    "Pacific/Auckland",
                ],
            },
            measurement_type: "total",
            ranges: [
                {
                    start: "1995-01-01",
                    end: "2024-12-31",
                    str_format: "%Y-%m-%d",
                    frequency: "P1DT0H0M0.000000S",
                },
            ],
            column_format: {
                dtype: "time_format_in_parts",
                year_column: "weather_year",
                month_column: "month",
                day_column: "day",
            },
        },
    ],
    dimension_references: [],
    trivial_dimensions: [],
    sector_description: "weather",
    data_source: "ERA5 reanalysis weather data combined with calculations similar to those described in: Staffell, Pfenninger, and Johnson. 2023. A global model of hourly space heating and cooling demand at multiple spatial scales. Nature Energy. 8, 1328-1344.",
    data_source_date: "2025",
    data_source_doi_url: "https://cds.climate.copernicus.eu/datasets/reanalysis-era5-single-levels?tab=overview;https://doi.org/10.1038/s41560-023-01341-5",
}