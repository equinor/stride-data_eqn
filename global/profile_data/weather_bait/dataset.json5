                    "Asia/Tokyo",
                    "Asia/Ulaanbaatar",
                    "Asia/Yangon",
                    "Asia/Yerevan",
                    "Australia/Brisbane",
                    "Europe/Athens",
                    "Europe/Belgrade",
                    "Europe/Berlin",
                    "Europe/Brussels",
                    "Europe/Bucharest",
                    "Europe/Budapest",
                    "Europe/Chisinau",
                    "Europe/Dublin",
                    "Europe/Helsinki",
                    "Europe/Istanbul",
                    "Europe/Kyiv",
                    "Europe/Lisbon",
                    "Europe/London",
                    "Europe/Madrid",
                    "Europe/Malta",
