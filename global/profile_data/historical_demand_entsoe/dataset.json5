{
    dataset_id: "baseline__historical_demand_entsoe",
    version: "1.0.0",
    dataset_type: "modeled",
    data_layout: {
        table_format: "one_table",
        value_format: "pivoted",
        pivoted_dimension_type: "metric",
        data_file: {
            path: "load_data.parquet",
            columns: [
                {
                    name: "geography",
                    dimension_type: "geography",
                },
            ],
        },
    },
    description: "Hourly total electricity demand from the ENTSO-E Transparency Platform. Covers EU/EEA + Switzerland countries from 2016–2024. Data is cleaned, gap-filled, and stored as MWh in local standard time (date components).",
    data_classification: "low",
    dimensions: [
        {
            type: "geography",
            "class": "Geography",
            module: "dsgrid.dimension.standard",
            name: "country",
            description: "Countries with historical demand data from ENTSO-E",
            file: "dimensions/countries.csv",
        },
        {
            type: "metric",
            "class": "EnergyEndUse",
            name: "total_load",
            description: "Total electricity demand",
            module: "dsgrid.dimension.standard",
            records: [
                {
                    id: "total_load_mwh",
                    name: "Total Electricity Demand",
                    fuel_id: "electricity",
                    unit: "MWh",
                },
            ],
        },
        {
            type: "weather_year",
            "class": "WeatherYear",
            name: "weather_year",
            description: "Years with ENTSO-E historical demand data",
            file: "dimensions/weather_years.csv",
        },
        {
            type: "time",
            time_type: "datetime",
            time_interval_type: "period_beginning",
            name: "hourly",
            description: "Hourly time resolution in local standard time",
            module: "dsgrid.dimension.standard",
            "class": "Time",
            measurement_type: "total",
            time_zone_format: {
                format_type: "aligned_in_std_clock_time",
                time_zones: ["Etc/GMT", "Etc/GMT-1", "Etc/GMT-2"],
            },
            ranges: [
                {
                    start: "2016-01-01 00:00",
                    end: "2024-12-31 23:00",
                    str_format: "%Y-%m-%d %H:%M",
                    frequency: "P0DT1H0M0.000000S",
                },
            ],
            column_format: {
                dtype: "time_format_in_parts",
                year_column: "weather_year",
                month_column: "month",
                day_column: "day",
                hour_column: "hour",
            },
        },
    ],
    dimension_references: [],
    trivial_dimensions: [],
    sector_description: "electricity",
    data_source: "ENTSO-E Transparency Platform",
    data_source_date: "2026",
    data_source_doi_url: "https://transparency.entsoe.eu/",
}
