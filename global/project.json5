{
    project_id: "stride_global",
    name: "stride_global",
    description: "Input data for the STRIDE application, country-level hourly with near-global coverage.",
    datasets: [],
    dimensions: {
        base_dimensions: [
            {
                type: "scenario",
                class: "Scenario",
                module: 'dsgrid.dimension.standard',
                name: "default",
                description: "Default scenario",
                records: [{id: "default", name: "default"}],
            },
            {
                type: "model_year",
                class: "ModelYear",
                module: 'dsgrid.dimension.standard',
                name: "all_model_years",
                description: "All years available for analysis in STRIDE",
                file: "dimensions/model_years.csv",
            },
            {
                type: "weather_year",
                class: "WeatherYear",
                module: 'dsgrid.dimension.standard',
                name: "all_weather_years",
                description: "All weather years available for analysis in STRIDE",
                file: "profile_data/weather_bait/dimensions/weather_years.csv",
            },
            {
                type: "geography",
                class: "Geography",
                module: 'dsgrid.dimension.standard',
                name: "country",
                description: "All countries available for analysis in STRIDE",
                file: "dimensions/countries.csv",
            },
            {
                type: "sector",
                class: "Sector",
                module: 'dsgrid.dimension.standard',
                name: "sector",
                description: "Sectors in the STRIDE global dataset",
                file: "dimensions/sectors.csv",
            },
            {
                type: "subsector",
                class: "Subsector",
                module: 'dsgrid.dimension.standard',
                name: "subsector",
                description: "Subsectors in the STRIDE global dataset",
                file: "dimensions/subsectors.csv",
            },
            {
                type: "metric",
                "class": "Population",
                name: "population",
                description: "Number of people",
                module: "dsgrid.dimension.standard",
                records: [
                    {id: "population", name: "population", unit: "people"},
                ],
            },
            {
                type: "metric",
                "class": "FractionalIndex",
                name: "hdi",
                description: "Human Development Index",
                module: "dsgrid.dimension.standard",
                records: [
                    {
                        id: "hdi",
                        name: "HDI",
                        unit: "HDI",
                        min_value: 0.0,
                        max_value: 1.0,
                    },
                ],
            },
            {
                type: "metric",
                "class": "Stock",
                name: "gdp",
                description: "Gross Domestic Product",
                module: "dsgrid.dimension.standard",
                records: [
                    {id: "gdp", name: "GDP", unit: "billion USD-2024"},
                ],
            },
            {
                type: "metric",
                "class": "EnergyIntensityRegression",
                name: "energy_intensity_regression",
                description: "Slope, intercept, and starting year (t0) parameters for energy intensity regressions. Supports linear and log-linear (exponential) regressions of energy intensity either per HDI-person or per GDP. Regressions describe change in energy intensity year over year.",
                file: "default_projection/energy_intensity_regressions/dimensions/energy_intensity_regression_parameters.csv",
            },
            {
                type: "metric",
                "class": "EnergyEndUse",
                name: "energy_end_use",
                description: "metric",
                file: "profile_data/load_shapes/dimensions/IMAGE_load_shape_enduses.csv",
                module: "dsgrid.dimension.standard",
            },
            {
                type: "metric",
                "class": "WeatherVariable",
                name: "weather_variable",
                description: "metric",
                module: "dsgrid.dimension.standard",
                records: [
                    {
                        id: "Temperature",
                        name: "dry-bulb temperature",
                        unit: "degree Celsius",
                    },
                    {
                        id: "Solar_Radiation",
                        name: "surface solar radiation",
                        unit: "W/m2",
                    },
                    {
                        id: "Wind_Speed",
                        name: "wind speed at 2m",
                        unit: "m/s",
                    },
                    {
                        id: "Dew_Point",
                        name: "dew point temperature",
                        unit: "degree Celsius",
                    },
                    {
                        id: "Humidity",
                        name: "humidity",
                        unit: "g/kg",
                    },
                    {
                        id: "BAIT",
                        name: "building-adjusted internal temperature",
                        unit: "degree Celsius",
                    },
                ],
            },
            {
                type: "metric",
                "class": "StockRegression",
                name: "stock_regression",
                description: "Slope, intercept, and starting year (t0) parameters for cars per capita linear regressions. Regressions describe change in the number of cars per person year over year.",
                file: "ev_projection/vehicle_per_capita_regressions/dimensions/vehicles_per_capita_regression_parameters.csv",
            },
            {
                type: "metric",
                "class": "EnergyServiceDemandRegression",
                name: "energy_service_demand_regression",
                description: "Slope, intercept, and starting year (t0) parameters for kilometers per vehicle year exponential regressions. Regressions describe change in the number of kilometers per vehicle year over time.",
                file: "ev_projection/km_per_vehicle_year_regressions/dimensions/km_per_vehicle_year_regression_parameters.csv",
            },
            {
                type: "metric",
                "class": "StockShare",
                name: "ev_stock_share",
                description: "Electric vehicle stock share",
                records: [
                    {
                        id: "ev_stock_share",
                        name: "EV Stock Share",
                        unit: "fraction",
                    },
                ],
            },
            {
                type: "metric",
                "class": "StockShare",
                name: "phev_stock_share",
                description: "Plug-in hybrid electric vehicle share of the electric vehicle stock",
                module: "dsgrid.dimension.standard",
                records: [
                    {
                        id: "phev_stock_share",
                        name: "PHEV Stock Share",
                        unit: "fraction",
                    },
                ],
            },
            {
                type: "metric",
                "class": "EnergyEfficiency",
                name: "electricity_per_vehicle_km",
                description: "Electricity consumption per vehicle kilometer",
                module: "dsgrid.dimension.standard",
                records: [
                    {
                        id: "Wh_per_vehicle_km",
                        name: "Electricity per Vehicle Kilometer",
                        fuel_id: "electricity",
                        unit: "Wh/km",
                    },
                ],
            },
            {
                type: "metric",
                "class": "EnergyEndUse",
                name: "total_load",
                description: "Total electricity demand from historical metered data",
                module: "dsgrid.dimension.standard",
                records: [
                    {
                        id: "total_load_mwh",
                        name: "Total Electricity Demand",
                        fuel_id: "electricity",
                        unit: "MWh",
                    },
                ],
            },
            {
              type: 'time',
              class: 'Time',
              name: 'time_est',
              time_type: 'datetime',
              description: 'Time dimension, 2018 hourly EST, hour-beginning, no Leap Day Adjustment, total value',
              time_interval_type: 'period_beginning',
              measurement_type: 'total',
              time_zone_format: {
                format_type: "aligned_in_absolute_time",
                time_zone: "Etc/GMT+5",
              },
              ranges: [
                {
                  start: '2018-01-01 00:00:00',
                  end: '2018-12-31 23:00:00',
                  str_format: '%Y-%m-%d %H:%M:%S',
                  frequency: 'P0DT1H0M0.000000S',
                },
              ],
            },
        ],
    },
}
